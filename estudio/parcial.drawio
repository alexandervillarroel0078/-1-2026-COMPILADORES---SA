                <mxCell id="374" value="&lt;div style=&quot;color: rgb(204, 204, 204); background-color: rgb(31, 31, 31); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(86, 156, 214); font-weight: bold;&quot;&gt;**2.**&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204); font-style: italic;&quot;&gt;*(Aplicación de los dt)*&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt; Asumiendo que el cabezal de la &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;Cinta de Caracteres está en la primera celda, &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;dibuje un dt &lt;/span&gt;&lt;span style=&quot;color: rgb(86, 156, 214); font-weight: bold;&quot;&gt;**sin acciones semánticas**&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;, que devuelva:&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(103, 150, 230);&quot;&gt;-&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(86, 156, 214); font-weight: bold;&quot;&gt;**true**&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt; si todas las palabras de la cinta tienen longitud par.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(103, 150, 230);&quot;&gt;-&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(86, 156, 214); font-weight: bold;&quot;&gt;**false**&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt; si alguna palabra de la cinta tiene longitud impar.&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;Se considera palabra a todo substring que no tiene espacios ni EOF.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=11;fontColor=default;labelBackgroundColor=default;" vertex="1" parent="1">
